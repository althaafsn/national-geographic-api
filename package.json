{
  "name": "national-geographic-api",
  "version": "1.0.0",
  "description": "National Geographic API wrapper — fetch Photo of the Day and latest news.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "rimraf ./dist && tsc",
    "build:watch": "tsc -w",
    "test": "jest --coverage",
    "test:watch": "jest --coverage --watchAll",
    "lint": "eslint src/**/*.ts scripts/**/*.ts",
    "wallpaper": "tsx scripts/wallpaper.ts",
    "setup-wallpaper": "bash setup-wallpaper.sh"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "rimraf": "^5.0.10",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "dependencies": {},
  "repository": {
    "type": "git",
    "url": "https://github.com/crisboarna/national-geographic-api.git"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": ["National", "Geographic", "API", "Photo", "News", "wallpaper"],
  "author": "Cristian Boarna <cristian.boarna@gmail.com>",
  "license": "MIT",
  "jest": {
    "roots": ["<rootDir>/tests"],
    "transform": {"^.+\\.ts?$": "ts-jest"},
    "testRegex": "(/__tests__/.*|(\\.|/)(test|spec))\\.(js?|ts?)$",
    "coverageReporters": ["text", "html", "lcov"],
    "coverageThreshold": {
      "global": {
        "branches": 100,
        "functions": 100,
        "lines": 100,
        "statements": 100
      }
    },
    "testEnvironment": "node",
    "collectCoverageFrom": ["src/**/*.ts"],
    "moduleFileExtensions": ["js", "ts"]
  }
}
